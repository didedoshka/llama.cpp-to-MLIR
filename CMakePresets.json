{
    "version": 3,
    "cmakeMinimumRequired": {
        "major": 3,
        "minor": 21
    },
    "configurePresets": [
        {
            "name": "default",
            "cacheVariables": {
                "FETCHCONTENT_SOURCE_DIR_LLAMA": "../llama.cpp",
                "GGML_METAL": "OFF"
            }
        },
        {
            "name": "debug",
            "inherits": "default",
            "binaryDir": "build_debug",
            "cacheVariables": {
                "CMAKE_BUILD_TYPE": "DEBUG"
            },
            "environment": {
                "MLIR_DIR": "/Users/didedoshka/programming/hse/compiler_term_project/installed_llvm"
            }
        },
        {
            "name": "release",
            "inherits": "default",
            "binaryDir": "build_release",
            "cacheVariables": {
                "CMAKE_BUILD_TYPE": "RELEASE"
            },
            "environment": {
                "MLIR_DIR": "/opt/homebrew/opt/llvm"
            }
        }
    ],
    "buildPresets": [
        {
            "name": "default",
            "configurePreset": "default"
        }
    ]
}
